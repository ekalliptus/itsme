---
// src/components/Footer.astro
const year = new Date().getFullYear();

const sitemap = [
  { href: '/about',    label: 'About'    },
  { href: '/skills',   label: 'Skills'   },
  { href: '/projects', label: 'Projects' },
  { href: '/contact',  label: 'Contact'  },
];

const socials = [
  { href: 'https://github.com/ekalliptus',               label: 'GitHub'   },
  { href: 'https://www.linkedin.com/in/ekalliptus/',     label: 'LinkedIn' },
];
---
<footer class="footer">
  <!-- CTA band -->
  <div class="container">
    <div class="footer-cta reveal">
      <p class="footer-cta-label section-label">Let's build</p>
      <h2 class="footer-cta-title">
        Have a project worth<br><span class="accent">shipping?</span>
      </h2>
      <a
        href="https://ekalliptus.com"
        class="btn btn-primary footer-cta-btn"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Start a project - ekalliptus.com"
      >
        Start a project
        <svg class="btn-arrow" viewBox="0 0 32 12" width="32" height="12" aria-hidden="true">
          <line class="btn-arrow-line" pathLength="100" x1="0" y1="6" x2="20" y2="6" />
          <path class="btn-arrow-head" d="M14 1 L22 6 L14 11" />
        </svg>
      </a>
    </div>
  </div>

  <!-- Columns -->
  <div class="container footer-grid">
    <div class="footer-brand">
      <span class="footer-logo">єкαℓℓιρтus</span>
      <p class="footer-tagline">
        Software Engineer crafting fast, polished web &amp; mobile products - built to run anywhere.
      </p>
    </div>

    <nav class="footer-col" aria-label="Sitemap">
      <span class="footer-col-head">Sitemap</span>
      {sitemap.map(l => <a href={l.href} class="footer-link">{l.label}</a>)}
    </nav>

    <nav class="footer-col" aria-label="Social links">
      <span class="footer-col-head">Connect</span>
      {socials.map(l => (
        <a href={l.href} class="footer-link" target="_blank" rel="noopener noreferrer">{l.label} ↗</a>
      ))}
    </nav>

    <div class="footer-col">
      <span class="footer-col-head">Get in touch</span>
      <a href="mailto:support@ekalliptus.com" class="footer-email">support@ekalliptus.com</a>
      <span class="footer-loc">Tegal, Jawa Tengah, Indonesia</span>
    </div>
  </div>

  <!-- Baseline -->
  <div class="container footer-base">
    <p class="footer-copy">&copy; {year} Haikal Akhalul Azhar</p>
    <span class="footer-avail">
      <span class="footer-dot" aria-hidden="true"></span>Available for work
    </span>
  </div>
</footer>

<style>
.footer {
  position: relative;
  z-index: 1;
  border-top: 1px solid var(--line-soft);
  margin-top: 120px;
  padding-top: 96px;
  content-visibility: auto;
  contain-intrinsic-size: auto 700px;
}

/* CTA band */
.footer-cta {
  text-align: center;
  padding-bottom: 96px;
  border-bottom: 1px solid var(--line-soft);
}
.footer-cta-label { justify-content: center; }
.footer-cta-label::before { display: none; }
.footer-cta-title {
  font-size: clamp(2rem, 6vw, 3.75rem);
  font-weight: 700;
  line-height: 1.05;
  letter-spacing: -0.025em;
  margin-bottom: 36px;
}
.footer-cta-title .accent { color: var(--accent); }
.footer-cta-btn { padding: 16px 36px; font-size: 0.875rem; }

/* Custom arrow: a short line that draws out to the head on hover,
   and the whole arrow nudges forward. No gaps - the line's far end
   always meets the arrowhead base. */
.footer-cta-btn { gap: 12px; }
.btn-arrow {
  flex-shrink: 0;
  transition: transform var(--transition);
}
.btn-arrow-line,
.btn-arrow-head {
  fill: none;
  stroke: currentColor;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}
/* Line draws out from the text side: pathLength (set as an SVG
   attribute on the <line>) normalises the path to 100, so dasharray
   100 + dashoffset 60 hides most of it, leaving a short segment flush
   with the arrowhead. Hover reveals the full line. */
.btn-arrow-line {
  stroke-dasharray: 100;
  stroke-dashoffset: 60;
  transition: stroke-dashoffset var(--transition);
}
.footer-cta-btn:hover .btn-arrow { transform: translateX(4px); }
.footer-cta-btn:hover .btn-arrow-line { stroke-dashoffset: 0; }

/* Columns */
.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1.4fr;
  gap: 48px;
  padding-top: 72px;
  padding-bottom: 56px;
}
.footer-logo {
  font-family: serif;
  font-size: 22px;
  font-weight: 700;
  color: var(--text);
  display: block;
  margin-bottom: 18px;
}
.footer-tagline {
  font-size: 0.875rem;
  color: var(--text-sec);
  line-height: 1.7;
  max-width: 34ch;
}
.footer-col {
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.footer-col-head {
  font-family: var(--font-mono);
  font-size: 0.6875rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--text-mut);
  margin-bottom: 6px;
}
.footer-link {
  font-size: 0.875rem;
  color: var(--text-sec);
  text-decoration: none;
  width: fit-content;
  transition: color var(--transition-fast);
}
.footer-link:hover { color: var(--accent); }
.footer-email {
  font-size: 0.875rem;
  color: var(--text);
  text-decoration: none;
  transition: color var(--transition-fast);
}
.footer-email:hover { color: var(--accent); }
.footer-loc { font-size: 0.8125rem; color: var(--text-mut); }

/* Baseline */
.footer-base {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16px;
  padding-top: 28px;
  padding-bottom: 40px;
  border-top: 1px solid var(--line-soft);
}
.footer-copy { font-size: 0.8125rem; color: var(--text-mut); }
.footer-avail {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.75rem;
  letter-spacing: 0.04em;
  color: var(--text-sec);
}
.footer-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #46d17f;
  box-shadow: 0 0 0 3px rgba(70, 209, 127, 0.18);
  animation: footpulse 2.4s var(--ease) infinite;
}
@keyframes footpulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

@media (max-width: 860px) {
  .footer-grid { grid-template-columns: 1fr 1fr; gap: 40px 32px; }
  .footer-brand { grid-column: 1 / -1; }
}
@media (max-width: 520px) {
  .footer { padding-top: 72px; }
  .footer-cta { padding-bottom: 72px; }
  .footer-grid { grid-template-columns: 1fr; }
  .footer-base { flex-direction: column; align-items: flex-start; }
}
</style>
