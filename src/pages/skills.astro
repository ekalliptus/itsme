---
// src/pages/skills.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import SkillsSphere from '../components/SkillsSphere.astro';
import { SKILLS_DATA } from '../data/skills.js';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Technical Skills - Haikal Akhalul Azhar',
  url: 'https://bio.ekalliptus.com/skills/',
  description: 'Technical skills and technologies used by Haikal Akhalul Azhar: Flutter, React, Next.js, Laravel, and more.',
  about: SKILLS_DATA.map(s => ({ '@type': 'Thing', name: s.name })),
};

const categories = [
  'Mobile', 'Frontend', 'Backend', 'Database', 'Languages', 'CSS / UI', 'Tools',
];
---
<BaseLayout
  title="Skills - Haikal Akhalul Azhar"
  description="Technical skills and technologies: Flutter, React, Next.js, Laravel, Node.js, TypeScript, Docker, and more."
  pageSchema={pageSchema}
>
  <div class="container section">
    <p class="section-label reveal">How I Work</p>
    <h1 class="section-title reveal">The tools behind<br><span class="accent">the work.</span></h1>
    <p class="section-desc reveal">
      Drag the sphere to explore. Every node is something I've shipped with across
      41 projects - from Flutter apps and Astro sites to Python tooling
      and Three.js scenes. I pick the tool that fits the problem, not the trend,
      and go deep enough to make what I build fast and reliable.
    </p>

    <SkillsSphere />

    <div class="legend reveal">
      {categories.map(cat => (
        <span class="legend-item">
          <span class="legend-dot"></span>
          {cat}
        </span>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
.legend {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  justify-content: center;
  margin-top: 24px;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--text-sec);
  font-family: var(--font-mono);
  letter-spacing: 1px;
}

.legend-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
  /* Optical alignment: centering on the full line box makes a small dot sit
     too high relative to the lowercase glyphs. Nudge it down to the text's
     optical centre (its x-height), not the line-box centre. */
  transform: translateY(1px);
}
</style>
