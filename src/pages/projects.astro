---
// src/pages/projects.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { PROJECTS, PROJECT_CATEGORIES } from '../data/projects.js';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Projects - Haikal Akhalul Azhar',
  url: 'https://bio.ekalliptus.com/projects',
  description: 'Portfolio of professional software engineering projects by Haikal Akhalul Azhar.',
  author: { '@type': 'Person', name: 'Haikal Akhalul Azhar' },
  hasPart: PROJECTS.map(p => ({
    '@type': 'WebSite',
    name: p.name,
    description: p.description,
    url: p.liveUrl,
  })),
};
---
<BaseLayout
  title="Projects - Haikal Akhalul Azhar"
  description={`Portfolio of ${PROJECTS.length} professional software engineering projects: web development, Islamic platforms, e-commerce, and more.`}
  pageSchema={pageSchema}
>
  <div class="container section">
    <p class="section-label reveal">My Work</p>
    <h1 class="section-title reveal">Selected<br><span class="accent">work.</span></h1>
    <p class="section-desc reveal">
      {PROJECTS.length} products shipped to production - web platforms, Islamic digital
      services, e-commerce, and public-facing tools for clients across Indonesia.
    </p>

    <!-- Category filter tabs -->
    <div class="filter-tabs reveal" role="tablist" aria-label="Filter projects by category">
      {PROJECT_CATEGORIES.map(cat => (
        <button
          class:list={['filter-btn', { active: cat.id === 'all' }]}
          data-filter={cat.id}
          role="tab"
          aria-selected={cat.id === 'all' ? 'true' : 'false'}
        >
          {cat.label}
          <span class="filter-count" data-count={cat.id}>
            {cat.id === 'all' ? PROJECTS.length : PROJECTS.filter(p => p.category === cat.id).length}
          </span>
        </button>
      ))}
    </div>

    <div class="projects-grid" id="projects-grid">
      {PROJECTS.map(project => (
        <div class="project-wrap" data-category={project.category}>
          <ProjectCard
            icon={project.icon}
            name={project.name}
            description={project.description}
            tags={project.tags}
            liveUrl={project.liveUrl}
            previewImage={project.previewImage}
          />
        </div>
      ))}
    </div>

    <p class="no-results" id="no-results" style="display:none">
      No projects in this category yet.
    </p>
  </div>
</BaseLayout>

<style>
.filter-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 32px;
}

.filter-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 16px;
  border-radius: var(--radius-pill);
  font-size: 13px;
  font-weight: 600;
  background: transparent;
  border: 1px solid var(--border-violet);
  color: var(--text-sec);
  cursor: pointer;
  transition: background var(--transition), border-color var(--transition), color var(--transition);
}

.filter-btn:hover {
  border-color: var(--border-violet-h);
  color: var(--text);
}

.filter-btn.active {
  background: var(--accent-soft);
  border-color: var(--accent-line);
  color: var(--accent);
}

.filter-count {
  font-size: 10px;
  font-family: var(--font-mono);
  background: rgba(255,255,255,0.08);
  padding: 1px 6px;
  border-radius: var(--radius-pill);
}

.filter-btn.active .filter-count {
  background: var(--accent-soft);
}

.projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
}

.project-wrap {
  transition: opacity 250ms ease, transform 250ms ease;
  content-visibility: auto;
  contain-intrinsic-size: auto 360px;
}

.project-wrap.hidden {
  display: none;
}

.no-results {
  text-align: center;
  color: var(--text-muted);
  font-family: var(--font-mono);
  font-size: 13px;
  letter-spacing: 1px;
  padding: 40px 0;
}
</style>

<script>
  function initFilter() {
    const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.project-wrap');
    const noResults = document.getElementById('no-results');

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter ?? 'all';

        // Update active button
        btns.forEach(b => {
          b.classList.toggle('active', b === btn);
          b.setAttribute('aria-selected', b === btn ? 'true' : 'false');
        });

        // Show/hide cards
        let visible = 0;
        cards.forEach(card => {
          const show = filter === 'all' || card.dataset.category === filter;
          card.classList.toggle('hidden', !show);
          if (show) visible++;
        });

        if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
      });
    });
  }

  document.addEventListener('astro:page-load', initFilter);
</script>
