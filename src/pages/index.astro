---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { PROJECTS } from '../data/projects.js';
import { PAGE_CONTENT_PATHS, resolveContentDate } from '../lib/content-dates.js';

const projectCount = PROJECTS.length;
const lastModified = resolveContentDate(PAGE_CONTENT_PATHS['/']);

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  name: 'Haikal Akhalul Azhar - Software Engineer Portfolio',
  url: 'https://bio.ekalliptus.com/',
  description: 'Portfolio of Haikal Akhalul Azhar, Software Engineer based in Tegal, Indonesia.',
  ...(lastModified ? { dateModified: lastModified } : {}),
  mainEntity: {
    '@type': 'Person',
    name: 'Haikal Akhalul Azhar',
    jobTitle: 'Software Engineer',
    url: 'https://bio.ekalliptus.com/',
  },
};

// Four pillars - my own structure, OHZI's editorial rhythm
const pillars = [
  {
    no: '01',
    label: 'WHO I AM',
    href: '/about/',
    title: 'A software engineer who ships products people actually use.',
    desc: 'Eight years building cross-platform mobile apps and full-stack web - clean architecture, smooth UI, and an eye for the details that make software feel finished.',
    cta: 'About me',
  },
  {
    no: '02',
    label: 'HOW I WORK',
    href: '/skills/',
    title: 'A stack I know deeply, picked to fit the problem.',
    desc: 'Flutter and Dart on mobile. React, Next.js, Astro, and Laravel on the web. I lean on tools I understand end-to-end, so what I ship stays quick, maintainable, and reliable.',
    cta: 'My stack',
  },
  {
    no: '03',
    label: 'MY WORK',
    href: '/projects/',
    title: `${projectCount} products delivered for clients across Indonesia.`,
    desc: 'Digital agencies, Islamic platforms, e-commerce, donation systems, and public services - real websites running in production for real organizations.',
    cta: 'See the work',
  },
  {
    no: '04',
    label: 'CONTACT',
    href: '/contact/',
    title: 'Got something to build? Let’s talk.',
    desc: 'Open for freelance projects, full-time roles, and consulting. Share what you have in mind and we’ll scope it from first idea to shipped product.',
    cta: 'Get in touch',
  },
];
---
<BaseLayout
  title="Haikal Akhalul Azhar - Software Engineer | IT Support Specialist | Editor"
  description="Software Engineer, IT Support Specialist, and Editor based in Tegal, Indonesia. Specializing in Flutter, React, Next.js, and Laravel development."
  pageSchema={pageSchema}
>
  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="hero">
    <canvas id="hero-field" class="hero-field" aria-hidden="true"></canvas>
    <div class="hero-field-mask" aria-hidden="true"></div>

    <div class="container hero-inner">
      <p class="hero-eyebrow reveal">
        <span class="hero-status-dot" aria-hidden="true"></span>
        Software Engineer · Available for work
      </p>

      <h1 class="hero-heading reveal">
        I build software<br>
        that <span class="accent">ships.</span>
      </h1>

      <p class="hero-sub reveal">
        <span id="typing-text" aria-live="polite" aria-label="Role"></span>
        <span class="typing-cursor" aria-hidden="true">_</span>
      </p>

      <p class="hero-desc reveal">
        Haikal Akhalul Azhar - a software engineer building cross-platform
        mobile apps and full-stack web products with Flutter, React, Next.js, and
        Laravel. Clean architecture, smooth UI, and details that make it feel finished.
      </p>

      <div class="hero-cta reveal">
        <a href="/projects/" class="btn btn-primary">View work</a>
        <a href="/contact/" class="btn btn-outline">Hire me</a>
      </div>
    </div>

    <!-- stat strip -->
    <div class="container">
      <div class="hero-stats reveal">
        <div class="hero-stat">
          <span class="hero-stat-num">8+</span>
          <span class="hero-stat-label">Years experience</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-num">{projectCount}</span>
          <span class="hero-stat-label">Projects shipped</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-num">3</span>
          <span class="hero-stat-label">Roles wearing one hat</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-num">∞</span>
          <span class="hero-stat-label">Cups of coffee</span>
        </div>
      </div>
    </div>

    <span class="hero-scroll" aria-hidden="true">Scroll to explore</span>
  </section>

  <!-- ── FOUR PILLARS ─────────────────────────────────────── -->
  <section class="pillars">
    <div class="container">
      {pillars.map(p => (
        <a href={p.href} class="pillar reveal">
          <span class="pillar-no">{p.no}</span>
          <div class="pillar-main">
            <span class="pillar-label">{p.label}</span>
            <h2 class="pillar-title">{p.title}</h2>
            <p class="pillar-desc">{p.desc}</p>
            <span class="pillar-cta">{p.cta} <span class="pillar-arrow">→</span></span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
/* ── HERO ── */
.hero {
  position: relative;
  min-height: calc(100vh - 96px);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 64px 0 96px;
  isolation: isolate;
}

/* 3D particle field - sits behind hero content */
.hero-field {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: -2;
  display: block;
  opacity: 0;
  transition: opacity 1200ms var(--ease);
}
.hero-field.ready { opacity: 1; }

/* Radial mask keeps the headline crisp over the field */
.hero-field-mask {
  position: absolute;
  inset: 0;
  z-index: -1;
  pointer-events: none;
  background:
    radial-gradient(80% 70% at 38% 42%, rgba(17,17,17,0.92), rgba(17,17,17,0.55) 45%, transparent 75%),
    linear-gradient(180deg, rgba(17,17,17,0.4) 0%, transparent 30%, transparent 70%, var(--bg) 100%);
}

.hero-inner { position: relative; z-index: 1; }

.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-mono);
  font-size: 0.75rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--text-sec);
  margin-bottom: 32px;
}
.hero-status-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: #46d17f;
  box-shadow: 0 0 0 4px rgba(70, 209, 127, 0.16);
}

.hero-heading {
  font-size: clamp(3rem, 9vw, 6.5rem);
  font-weight: 800;
  line-height: 0.98;
  letter-spacing: -0.04em;
  margin-bottom: 28px;
}
.hero-heading .accent { color: var(--accent); }

.hero-sub {
  font-size: clamp(1.1rem, 2vw, 1.5rem);
  color: var(--accent);
  font-family: var(--font-mono);
  font-weight: 500;
  min-height: 2rem;
  margin-bottom: 24px;
  letter-spacing: 0.01em;
}
.typing-cursor { animation: blink 1.1s steps(1) infinite; }
@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

.hero-desc {
  font-size: clamp(1rem, 1.5vw, 1.1875rem);
  color: var(--text-sec);
  line-height: 1.7;
  max-width: 58ch;
  margin-bottom: 40px;
}

.hero-cta { display: flex; gap: 14px; flex-wrap: wrap; }

/* stat strip */
.hero-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
  margin-top: 80px;
  padding-top: 40px;
  border-top: 1px solid var(--line-soft);
}
.hero-stat { display: flex; flex-direction: column; gap: 8px; }
.hero-stat-num {
  font-size: clamp(2rem, 4vw, 3.125rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1;
}
.hero-stat-label {
  font-size: 0.75rem;
  letter-spacing: 0.04em;
  color: var(--text-mut);
}

.hero-scroll {
  position: absolute;
  bottom: 28px;
  left: 50%;
  transform: translateX(-50%);
  font-family: var(--font-mono);
  font-size: 0.625rem;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--text-faint);
  animation: scrollnudge 2.4s var(--ease) infinite;
}
@keyframes scrollnudge {
  0%, 100% { transform: translateX(-50%) translateY(0); opacity: 0.5; }
  50% { transform: translateX(-50%) translateY(6px); opacity: 1; }
}

/* ── PILLARS ── */
.pillars {
  padding: 40px 0 80px;
  content-visibility: auto;
  contain-intrinsic-size: auto 1400px;
}

.pillar {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 40px;
  padding: 56px 0;
  border-top: 1px solid var(--line-soft);
  text-decoration: none;
  transition: padding-left var(--transition);
}
.pillar:last-child { border-bottom: 1px solid var(--line-soft); }
.pillar:hover { padding-left: 16px; }

.pillar-no {
  font-family: var(--font-mono);
  font-size: 1rem;
  font-weight: 500;
  color: var(--text-faint);
  padding-top: 6px;
  transition: color var(--transition);
}
.pillar:hover .pillar-no { color: var(--accent); }

.pillar-label {
  display: block;
  font-family: var(--font-mono);
  font-size: 0.6875rem;
  letter-spacing: 0.22em;
  color: var(--text-mut);
  margin-bottom: 18px;
}
.pillar-title {
  font-size: clamp(1.5rem, 3.4vw, 2.5rem);
  font-weight: 700;
  line-height: 1.12;
  letter-spacing: -0.025em;
  color: var(--text);
  max-width: 22ch;
  margin-bottom: 18px;
  transition: color var(--transition);
}
.pillar:hover .pillar-title { color: var(--accent); }
.pillar-desc {
  font-size: 0.9375rem;
  color: var(--text-sec);
  line-height: 1.7;
  max-width: 56ch;
  margin-bottom: 22px;
}
.pillar-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text);
}
.pillar-arrow { transition: transform var(--transition); }
.pillar:hover .pillar-arrow { transform: translateX(6px); }

@media (max-width: 768px) {
  .hero { min-height: auto; padding: 32px 0 64px; }
  .hero-stats { grid-template-columns: 1fr 1fr; gap: 28px 20px; margin-top: 56px; }
  .hero-scroll { display: none; }
  .pillar { grid-template-columns: 1fr; gap: 12px; padding: 40px 0; }
  .pillar:hover { padding-left: 0; }
  .pillar-no { padding-top: 0; }
}
</style>

<script>
  let typingTimeout: ReturnType<typeof setTimeout> | null = null;

  document.addEventListener('astro:before-swap', () => {
    if (typingTimeout !== null) clearTimeout(typingTimeout);
    typingTimeout = null;
  });

  function initTyping() {
    const el = document.getElementById('typing-text');
    if (!el) return;

    const texts = ['Software Engineer', 'IT Support Specialist', 'Editor'];
    let ti = 0, ci = 0, del = false;

    function tick() {
      if (!el) return;
      const cur = texts[ti];
      el.textContent = del ? cur.slice(0, ci - 1) : cur.slice(0, ci + 1);
      del ? ci-- : ci++;
      let spd = del ? 60 : 130;
      if (!del && ci === cur.length) { spd = 1800; del = true; }
      else if (del && ci === 0) { del = false; ti = (ti + 1) % texts.length; }
      typingTimeout = setTimeout(tick, spd);
    }

    tick();
  }

  document.addEventListener('astro:page-load', initTyping);

  // ── 3D hero field ──
  // Three.js (~469 KB) is heavy, so we DEFER it off the critical path:
  // the hero text paints first, then the field loads when the browser is idle.
  let heroField: { dispose: () => void } | null = null;
  let fieldLoading = false;

  function loadField() {
    if (heroField || fieldLoading) return;
    const canvas = document.getElementById('hero-field') as HTMLCanvasElement | null;
    if (!canvas) return;
    // Skip the cost entirely for users who prefer reduced motion on slow links
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches &&
        (navigator as any).connection?.saveData) return;

    fieldLoading = true;
    import('../scripts/hero-field.js').then(({ initHeroField }) => {
      const c = document.getElementById('hero-field') as HTMLCanvasElement | null;
      if (!c) { fieldLoading = false; return; }
      heroField = initHeroField(c);
      if (heroField) requestAnimationFrame(() => c.classList.add('ready'));
      fieldLoading = false;
    });
  }

  function scheduleField() {
    const ric = (window as any).requestIdleCallback as
      | ((cb: () => void, opts?: { timeout: number }) => number)
      | undefined;
    if (ric) ric(loadField, { timeout: 2000 });
    else setTimeout(loadField, 600);
  }

  function disposeField() {
    if (heroField) { heroField.dispose(); heroField = null; }
  }

  document.addEventListener('astro:page-load', scheduleField);
  document.addEventListener('astro:before-swap', disposeField);
</script>
