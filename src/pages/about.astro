---
// src/pages/about.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import LazyImage from '../components/LazyImage.astro';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Haikal Akhalul Azhar',
  url: 'https://bio.ekalliptus.com/about/',
  description: 'Software Engineer, IT Support Specialist, and Editor based in Tegal, Indonesia with 8+ years of experience.',
  mainEntity: {
    '@type': 'Person',
    name: 'Haikal Akhalul Azhar',
    jobTitle: 'Software Engineer',
    description: 'Passionate Software Engineer focused on Flutter mobile apps and full-stack web development using React, Next.js, and Laravel.',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Tegal',
      addressCountry: 'ID',
    },
    hasOccupation: [
      { '@type': 'Occupation', name: 'Software Engineer' },
      { '@type': 'Occupation', name: 'IT Support Specialist' },
      { '@type': 'Occupation', name: 'Editor' },
    ],
    offers: {
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: 'Software Engineering Services',
        description: 'Custom web and mobile application development using Flutter, React, Next.js, and Laravel.',
      },
    },
  },
};

const expertise = [
  {
    icon: '📱',
    title: 'Mobile Development',
    desc: 'Cross-platform apps in Flutter and Dart - from booking flows to social downloaders - built on clean architecture with smooth UI and state management that scales past the first screen.',
  },
  {
    icon: '🌐',
    title: 'Modern Web',
    desc: 'Production sites in Astro, TypeScript, Vue, and Next.js, styled with Tailwind and shadcn. Recent work leans into Three.js for interactive 3D and View Transitions for motion that feels native.',
  },
  {
    icon: '⚙️',
    title: 'Backend & Tooling',
    desc: 'APIs and services with Node.js, Express, Laravel, and Go, backed by MySQL and PostgreSQL. Plus Python automation and CLI tools when a script saves a hundred manual steps.',
  },
  {
    icon: '🛠️',
    title: 'Systems & Support',
    desc: 'Comfortable below the app layer too - Linux, Docker, Git, Bash, and low-level tinkering from Hackintosh builds to Android kernels. The IT-support instinct that keeps things actually running.',
  },
];
---
<BaseLayout
  title="About - Haikal Akhalul Azhar"
  description="Software Engineer, IT Support Specialist, and Editor based in Tegal, Indonesia with 8+ years of experience building cross-platform mobile and web solutions."
  pageSchema={pageSchema}
>
  <div class="container section">
    <p class="section-label reveal">Who I Am</p>
    <h1 class="section-title reveal">Engineer, problem-solver,<br><span class="accent">detail obsessive.</span></h1>

    <div class="about-grid">
      <!-- Profile card -->
      <div class="profile-card card reveal">
        <div class="profile-img-wrap">
          <LazyImage
            src="/img/ekal.webp"
            alt="Haikal Akhalul Azhar"
            width={280}
            height={280}
            loading="eager"
            fetchpriority="high"
            radius="50%"
          />
        </div>
        <div class="profile-info">
          <h2 class="profile-name">Haikal Akhalul Azhar</h2>
          <p class="profile-title">Software Engineer · IT Support Specialist · Editor</p>
          <span class="status-badge">
            <span class="status-dot" aria-hidden="true"></span>
            Available for Hire
          </span>
        </div>
      </div>

      <!-- Bio + expertise -->
      <div class="about-content">
        <div class="card bio-card reveal">
          <p class="bio-text">
            I'm a <strong>Software Engineer</strong> who likes building things end to end - mobile apps in Flutter, web platforms in Astro and TypeScript, and the backends that hold them together. Clean architecture and a UI that feels finished are non-negotiables for me, not afterthoughts.
          </p>
          <p class="bio-text">
            Across <strong>41 projects</strong> I've shipped everything from Islamic donation platforms and school systems to social-media tooling and interactive 3D sites. I reach for <strong>Vue, Next.js, Laravel, Go, and Python</strong> depending on what the problem actually needs, not what's trending that week.
          </p>
          <p class="bio-text">
            I'm just as happy below the app layer - Linux, Docker, Bash, and the occasional Hackintosh or Android-kernel rabbit hole. That IT-support instinct means I care about software that keeps running, and I'm always up for collaborating on open-source work.
          </p>
        </div>

        <div class="expertise-grid">
          {expertise.map(item => (
            <div class="expertise-card card reveal">
              <span class="expertise-icon">{item.icon}</span>
              <h3 class="expertise-title">{item.title}</h3>
              <p class="expertise-desc">{item.desc}</p>
            </div>
          ))}
        </div>

        <div class="cv-card card reveal">
          <h3 class="cv-title">View My Resume</h3>
          <p class="cv-desc">8+ years of experience delivering React, Next.js, Laravel, and Flutter projects for clients across Indonesia.</p>
          <a
            href="https://anrdart-my.sharepoint.com/:f:/g/personal/haikalalul_ekalliptus_com/IgC0qjuiQDUxTpPOP-Nhw7XoAWMPrOrwWCVpBOwKT7ILYjE?e=xOrezY"
            class="btn btn-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            View CV ↗
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
.about-grid {
  display: grid;
  grid-template-columns: 300px 1fr;
  gap: 32px;
  align-items: start;
}

.profile-card {
  position: sticky;
  top: 100px;
  text-align: center;
  padding: 28px;
}

.profile-img-wrap {
  width: 180px;
  height: 180px;
  margin: 0 auto 20px;
  border-radius: 50%;
  overflow: hidden;
  border: 1px solid var(--accent-line);
}

.profile-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.profile-name {
  font-size: 1.1rem;
  font-weight: 700;
  margin-bottom: 4px;
}

.profile-title {
  font-size: 12px;
  color: var(--text-sec);
  margin-bottom: 14px;
  line-height: 1.5;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.04em;
  color: var(--text-sec);
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--line);
  border-radius: var(--radius-pill);
  padding: 5px 13px;
}

.status-dot {
  width: 7px;
  height: 7px;
  background: #46d17f;
  box-shadow: 0 0 0 3px rgba(70, 209, 127, 0.18);
  border-radius: 50%;
  animation: pulse 2.4s var(--ease) infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.bio-card {
  margin-bottom: 20px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.bio-text {
  font-size: 0.95rem;
  color: var(--text-sec);
  line-height: 1.75;
}

.bio-text strong {
  color: var(--text);
  font-weight: 600;
}

.expertise-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 20px;
}

.expertise-card {
  padding: 20px;
}

.expertise-icon {
  font-size: 1.8rem;
  margin-bottom: 10px;
  display: block;
}

.expertise-title {
  font-size: 0.9rem;
  font-weight: 700;
  margin-bottom: 8px;
  color: var(--violet-light);
}

.expertise-desc {
  font-size: 12px;
  color: var(--text-sec);
  line-height: 1.65;
}

.cv-card {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.cv-title {
  font-size: 1rem;
  font-weight: 700;
}

.cv-desc {
  font-size: 13px;
  color: var(--text-sec);
}

@media (max-width: 900px) {
  .about-grid {
    grid-template-columns: 1fr;
  }

  .profile-card {
    position: static;
  }

  .expertise-grid {
    grid-template-columns: 1fr;
  }
}
</style>
